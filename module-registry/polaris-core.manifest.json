{
  "module_id": "polaris-core",
  "module_type": "Orchestrator",
  "version": "1.0.0",
  "purpose": "Central orchestration, task planning, routing and risk-confidence assessment for the regulated MVP.",
  "capabilities": [
    "task_planning",
    "routing",
    "risk_confidence_assessment"
  ],
  "dependencies": [
    "agent-registry",
    "policy-engine",
    "knowledge-layer",
    "audit-store"
  ],
  "allowed_connectors": [],
  "policy_profile": "open",
  "review_policy": {
    "rules": [
      {
        "trigger": "confidence_below_threshold",
        "threshold": 0.83,
        "action": "human_review"
      },
      {
        "trigger": "policy_violation",
        "action": "block"
      }
    ]
  },
  "health_signals": [
    "health",
    "metrics"
  ],
  "output_contract": {
    "output_type": "task_plan",
    "required_fields": [
      "plan_ref",
      "decision_ref"
    ],
    "audit_referenceable": true
  },
  "fallback_action": "human_review"
}
